# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_production_bot_token
TELEGRAM_TEST_BOT_TOKEN=your_test_bot_token

# --- OpenAI ---
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1

# --- PostgreSQL (Supabase pooler) ---
DATABASE_URL=postgresql://postgres.xxxx:password@aws-1-eu-central-2.pooler.supabase.com:5432/postgres

# --- Webhook ---
WEBHOOK_DOMAIN=https://your-app.up.railway.app
PORT=8080

# --- App settings ---
# development = polling mode (local), production = webhook mode
ENV=development
